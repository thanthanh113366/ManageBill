rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rules cho collection menuItems
    // Khách hàng cần đọc để xem menu khi order
    match /menuItems/{document} {
      allow read: if true;  // Public read cho khách hàng
      allow write: if true; // Write cho admin (nên thêm auth sau)
    }

    // Rules cho collection orderItems
    // Khách hàng cần đọc để xem menu khi order
    match /orderItems/{document} {
      allow read: if true;  // Public read cho khách hàng
      allow write: if true; // Write cho admin (nên thêm auth sau)
    }

    // Rules cho collection tables
    // Khách hàng cần đọc để xem thông tin bàn
    match /tables/{document} {
      allow read: if true;  // Public read
      allow write: if true; // Write cho admin (nên thêm auth sau)
    }

    // Rules cho collection bills
    // Khách hàng cần tạo và cập nhật đơn hàng của mình
    match /bills/{document} {
      // Public read - khách xem hóa đơn
      allow read: if true;

      // Cho phép khách tạo đơn mới
      allow create: if true && 
        request.resource.data.keys().hasAll(['createdAt', 'date', 'tableNumber', 'items', 'totalRevenue', 'totalProfit']) &&
        request.resource.data.items.size() > 0 &&
        request.resource.data.totalRevenue >= 0 &&
        request.resource.data.totalProfit >= 0;

      // Cho phép khách và admin cập nhật đơn (gọi thêm món)
      allow update: if true;

      // Cho phép xóa (trong production nên thêm authentication)
      allow delete: if true;
    }

    // Temporary active bill lock per date/table to prevent duplicate pending bills.
    match /activeBills/{document} {
      allow read: if true;
      allow write: if true;
    }

    // Daily counter for takeaway order numbers.
    match /takeawayCounters/{document} {
      allow read: if true;
      allow write: if true;
    }

    // Rules cho collection menuItemTimings
    // Admin cần đọc/ghi để quản lý timing món ăn
    match /menuItemTimings/{document} {
      allow read: if true;  // Public read cho bếp
      allow write: if true; // Write cho admin (nên thêm auth sau)
    }

    // Rules cho collection config (passwords, settings...)
    match /config/{document} {
      allow read: if true;
      allow write: if false;  // Chỉ admin qua backend
    }

    // Cài đặt vận hành công khai như QR thanh toán mặc định.
    match /appSettings/{document} {
      allow read: if true;
      allow write: if true;
    }

    // ===== Module quản lý vốn hàng ngày & P&L =====
    // Note: Production cần siết write theo auth (đồng bộ với menuItems/bills hiện tại).

    // Danh mục nguyên liệu / chi phí (cogs, opex_variable, opex_fixed)
    match /expenseCategories/{document} {
      allow read: if true;
      allow write: if true;
    }

    // Phiếu chi mỗi ngày (đi chợ + chi biến đổi)
    match /dailyExpenses/{document} {
      allow read: if true;
      allow write: if true;
    }

    // Chi phí cố định theo tháng (lương, mặt bằng, internet...)
    match /monthlyFixedCosts/{document} {
      allow read: if true;
      allow write: if true;
    }

    // Cài đặt P&L (taxRate, taxMode, depreciationMonthly, otherReservePercent)
    match /pnlSettings/{document} {
      allow read: if true;
      allow write: if true;
    }
  }
} 
