# ===== App =====
VITE_ADMIN_PASSWORD=your-admin-password

# ===== Firebase =====
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ===== Voice Metrics (Frontend -> same-origin proxy) =====
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=/api/otlp
VITE_METRICS_SOURCE=app_ui

# ===== Voice Metrics Proxy (Server-side on Vercel) =====
METRICS_PROXY_ENABLED=true
METRICS_PROXY_TIMEOUT_MS=5000
GRAFANA_OTLP_URL=https://otlp-gateway-prod-ap-southeast-1.grafana.net/otlp/v1/metrics
# Format: Basic <base64(instance_id:api_token)>
GRAFANA_OTLP_AUTH=Basic your-base64-credential
